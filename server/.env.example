# Enterprise NMS backend configuration (air-gapped deployment)
NODE_ENV=production
PORT=4000

# PostgreSQL
DATABASE_URL=postgres://nms:nms_secret@postgres:5432/nms

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12

# Initial admin account (created on first migration if missing)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe!2024

# Monitoring engine
POLL_INTERVAL_SECONDS=30
ICMP_PACKET_COUNT=4
ICMP_TIMEOUT_SECONDS=2
SNMP_COMMUNITY=public
SNMP_PORT=161
SNMP_TIMEOUT_MS=1500
WORKER_POOL_SIZE=5

# CORS (frontend origin served by nginx)
CORS_ORIGIN=http://localhost

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
